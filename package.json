{
  "name": "secure-crypto-kit",
  "version": "1.0.1",
  "description": "End-to-end hybrid encryption (RSA-OAEP + AES-256-GCM) with replay protection and HMAC integrity for browser ↔ Node.js communication.",
  "author": "Subhransu Sekhar Panda",
  "license": "MIT",
  "keywords": [
    "encryption",
    "rsa",
    "aes-gcm",
    "webcrypto",
    "hybrid-encryption",
    "replay-protection",
    "hmac",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Subhransu02/secure-crypto-kit.git"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.mjs",
      "types": "./dist/types/index.d.mts"
    },
    "./fe": {
      "import": "./dist/esm/fe/index.mjs",
      "require": "./dist/cjs/fe/index.mjs",
      "types": "./dist/types/fe/index.d.mts"
    },
    "./be": {
      "require": "./src/be/index.js",
      "import": "./src/be/index.js",
      "types": "./src/be/index.d.ts"
    }
  },
  "main": "./src/be/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
